# Copy to `.env.local` and fill in values. Never commit `.env.local`.
#
# OpenAI API keys: https://platform.openai.com/api-keys
# Models: https://platform.openai.com/docs/models
# Upstash: https://console.upstash.com/ → Create database → REST API → URL + token

OPENAI_API_KEY=
# Optional overrides (defaults: gpt-4o for chat, gpt-4o-mini for judge/ledger/ping):
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_CHAT_MODEL=gpt-4o
# OPENAI_SMALL_MODEL=gpt-4o-mini

# Upstash → Redis → REST API tab (URL must be https, no trailing slash issues for @upstash/redis)
UPSTASH_REDIS_REST_URL=https://your-db-xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
